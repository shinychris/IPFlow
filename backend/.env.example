# ==========================================
# IPFlow 环境变量配置模板
# 复制为 .env 并根据需要修改
# ==========================================

# 应用配置
APP_NAME=IPFlow
DEBUG=false
ENVIRONMENT=development

# 安全配置 (生产环境必须修改!)
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ipflow
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# 存储配置 (MinIO)
STORAGE_TYPE=minio
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=ipflow
STORAGE_REGION=us-east-1
STORAGE_USE_SSL=false

# Celery 配置
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# 邮件配置 (可选)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json

# 功能开关
ENABLE_REGISTRATION=true
ENABLE_AI_ASSISTANT=false

# 软著 AI 草稿：template | claude_code
COPYRIGHT_DRAFT_BACKEND=template
COPYRIGHT_DRAFT_FALLBACK_TO_TEMPLATE=false
CLAUDE_CODE_BIN=claude
CLAUDE_CODE_SKILL_PROMPT_FILE=resources/skills/software-copyright-application/SKILL.md
CLAUDE_CODE_OUTPUT_SCHEMA_PATH=resources/schemas/copyright_draft_output.schema.json
CLAUDE_CODE_TIMEOUT_SECONDS=600
CLAUDE_CODE_MAX_TURNS=32
CLAUDE_CODE_BARE_MODE=true
CLAUDE_CODE_ALLOWED_TOOLS=Read
CLAUDE_CODE_PERMISSION_MODE=bypassPermissions
# CLAUDE_CODE_SETTINGS_FILE=/path/to/claude-settings.json
# 远程源码：逗号分隔 host，空则禁止拉取（示例：github.com,git.example.com）
SOURCE_FETCH_ALLOWED_HOSTS=
SOURCE_FETCH_MAX_ZIP_BYTES=100000000
SOURCE_FETCH_MAX_EXTRACTED_BYTES=500000000
SOURCE_FETCH_WORKDIR_BASE=/tmp/ipflow-source-fetch
GIT_CLONE_DEPTH=1

# 专利 AI 草稿：template | claude_code
PATENT_DRAFT_BACKEND=template
PATENT_DRAFT_FALLBACK_TO_TEMPLATE=false
CLAUDE_CODE_PATENT_SKILL_PROMPT_FILE=resources/skills/patent-application/SKILL.md
CLAUDE_CODE_PATENT_OUTPUT_SCHEMA_PATH=resources/schemas/patent_draft_output.schema.json

# 商标 AI 草稿：template | claude_code
TRADEMARK_DRAFT_BACKEND=template
TRADEMARK_DRAFT_FALLBACK_TO_TEMPLATE=false
CLAUDE_CODE_TRADEMARK_SKILL_PROMPT_FILE=resources/skills/trademark-application/SKILL.md
CLAUDE_CODE_TRADEMARK_OUTPUT_SCHEMA_PATH=resources/schemas/trademark_draft_output.schema.json
