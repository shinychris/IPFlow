# ============================================
# IPFlow 环境变量配置示例
# 复制此文件为 .env 并修改为您的配置
# ============================================

# --------------------------------------------
# 应用配置
# --------------------------------------------
APP_NAME=IPFlow
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# --------------------------------------------
# 数据库配置 (PostgreSQL)
# --------------------------------------------
DATABASE_URL=postgresql://ipflow:password@localhost:5432/ipflow
# 或分别配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ipflow
DB_USER=ipflow
DB_PASSWORD=password

# --------------------------------------------
# Redis 配置
# --------------------------------------------
REDIS_URL=redis://localhost:6379/0
# 或分别配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --------------------------------------------
# MinIO / S3 对象存储配置
# --------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=ipflow
MINIO_SECURE=false

# AWS S3 配置（如果使用 AWS S3）
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=ipflow

# --------------------------------------------
# JWT 认证配置
# --------------------------------------------
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --------------------------------------------
# 邮件配置（可选）
# --------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-email-password
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=IPFlow

# --------------------------------------------
# 支付配置（可选）
# --------------------------------------------
# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# 支付宝
ALIPAY_APP_ID=your-app-id
ALIPAY_PRIVATE_KEY=your-private-key
ALIPAY_PUBLIC_KEY=alipay-public-key

# 微信支付
WECHAT_PAY_APP_ID=your-app-id
WECHAT_PAY_MCH_ID=your-mch-id
WECHAT_PAY_API_KEY=your-api-key

# --------------------------------------------
# Celery 任务队列配置（可选）
# --------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --------------------------------------------
# 日志配置
# --------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# --------------------------------------------
# 安全配置
# --------------------------------------------
# 允许的 CORS 源（生产环境）
ALLOWED_ORIGINS=https://ipflow.com,https://www.ipflow.com

# 速率限制
RATE_LIMIT_REQUESTS_PER_MINUTE=60
