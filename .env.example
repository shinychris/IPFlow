# ==========================================
# IPFlow 环境变量配置模板（根目录）
# 同步 backend/src/ipflow/config.py
# ==========================================

# 应用配置
APP_NAME=IPFlow
DEBUG=false
ENVIRONMENT=development

# 安全配置（生产必须替换）
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 数据库（异步驱动）
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ipflow
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0

# 存储（MinIO/S3）
STORAGE_TYPE=minio
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=ipflow
STORAGE_REGION=us-east-1
STORAGE_USE_SSL=false

# Celery（可选）
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# 日志
LOG_LEVEL=INFO
LOG_FORMAT=json

# 功能开关
ENABLE_REGISTRATION=true
ENABLE_AI_ASSISTANT=false

# AI（可选）
AI_PROVIDER=ollama
AI_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_TIMEOUT=120
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_DEFAULT_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_DEFAULT_MODEL=claude-3-haiku-20240307

# 前端（Next.js）
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# 应用配置 - CORS 允许的前端来源白名单（逗号分隔）。
# 生产环境必须配置明确域名，否则前端将无法携带凭证调用 API。
# 开发环境留空时自动回退到 http://localhost:3000。
# CORS_ALLOWED_ORIGINS=https://app.ipflow.com,https://www.ipflow.com

# Stripe 支付（真实收款，商业化必需）
# 申请：https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_xxxxx          # 测试密钥（生产换 sk_live_）
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx         # Webhook 端点签名密钥
# STRIPE_PRICE_MAP=starter:monthly=price_abc,starter:yearly=price_def,professional:monthly=price_ghi,professional:yearly=price_jkl
# APP_BASE_URL=http://localhost:3000        # 应用基础 URL（拼接 Checkout 回跳地址）
